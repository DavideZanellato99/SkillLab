# SkillLab backend — environment template.
# Copy to `.env` and fill in the real values:  cp .env.example .env
# Every variable below is read at import time; the ones marked REQUIRED make
# the app raise RuntimeError on startup if missing (see database.py,
# main.py, cognito_service.py, cartesia_service.py, elevenlabs_service.py,
# openai_service.py). The CI uses this file, with these placeholder values,
# to boot the app for the smoke test — real secrets never go in here.

# --- Database (REQUIRED) ---------------------------------------------------
# Local native Postgres. In docker-compose the value is overridden to point
# at the "db" service; the compose smoke test uses that override.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/skilllab_db

# --- CORS (REQUIRED) -------------------------------------------------------
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:3000

# --- AWS Cognito (REQUIRED: region; pool/client needed for real auth) ------
COGNITO_REGION=eu-west-1
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# --- OpenAI (REQUIRED: models) ---------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EVAL_MODEL=gpt-4o
# Optional comma-separated fallbacks tried in order if the primary fails.
OPENAI_FALLBACK_MODELS=
OPENAI_EVAL_FALLBACK_MODELS=

# --- Cartesia TTS (REQUIRED: model, version, language, ws url) -------------
CARTESIA_API_KEY=
CARTESIA_MODEL=sonic-2
CARTESIA_VERSION=2024-11-13
CARTESIA_LANGUAGE=it
CARTESIA_DEFAULT_VOICE_ID=
CARTESIA_TTS_WS_URL=wss://api.cartesia.ai/tts/websocket

# --- ElevenLabs STT (REQUIRED: model, language, VAD, ws url) ---------------
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v1
ELEVENLABS_STT_LANGUAGE=it
# Seconds of silence that end an utterance.
ELEVENLABS_VAD_SILENCE_SECS=0.8
# Voice-activity threshold, must be between 0.1 and 0.9.
ELEVENLABS_VAD_THRESHOLD=0.5
ELEVENLABS_STT_WS_URL=wss://api.elevenlabs.io/v1/speech-to-text/stream

# --- Optional --------------------------------------------------------------
# Set to 0/false/no to silence the per-turn voice latency log.
VOICE_LATENCY_LOG=1
