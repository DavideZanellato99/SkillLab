# Copy to backend/.env and fill in real values. backend/.env is gitignored
# and, when running via docker-compose, DATABASE_URL below is overridden
# automatically to point at the "db" service — leave it as-is or omit it.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/skilllab_db

# AWS Cognito (auth)
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# OpenAI (conversation + evaluation)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EVAL_MODEL=gpt-5.6-terra
OPENAI_FALLBACK_MODELS=
OPENAI_EVAL_FALLBACK_MODELS=gpt-5.1,gpt-4.1-mini

# ElevenLabs (speech-to-text)
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2_realtime
ELEVENLABS_STT_LANGUAGE=it
ELEVENLABS_VAD_SILENCE_SECS=0.8

# Cartesia (text-to-speech)
CARTESIA_API_KEY=
CARTESIA_MODEL=sonic-3.5
CARTESIA_VERSION=2026-03-01
CARTESIA_DEFAULT_VOICE_ID=
CARTESIA_LANGUAGE=it
